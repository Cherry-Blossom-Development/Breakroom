# Copy to /etc/custom-domain-agent.env on the EC2 host (chmod 600, owned by
# the customdomain user) and fill in real values. Referenced by
# custom-domain-agent.service's EnvironmentFile= — kept separate from the
# Docker backend's .env since this runs outside Docker entirely.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=DCAdminUser
DB_PASS=changeme
DB_NAME=breakroom

# The EC2 host's public IP — must match what artists are told to point their
# DNS A records at. Confirm this is an Elastic IP (persistent), not the
# instance's ephemeral default, before going live (see plan pre-flight checks).
CUSTOM_DOMAIN_TARGET_IP=44.225.148.34

CERTBOT_EMAIL=admin@prosaurus.com

# Set to "true" while testing the flow end-to-end on a NEW host, so certbot
# hits the Let's Encrypt staging environment (far more generous rate limits)
# instead of production. Flip to unset/false only once the flow is proven on
# THIS host — the code path itself was already proven live once, for
# carolearts.com on 2026-07-03 (see infra/systemd/README.md "Status"
# section), but a new host should still start with staging=true regardless.
CERTBOT_STAGING=true

# Required — not actually optional. The script's built-in default template
# path assumes a nested infra/ subfolder, but the real deploy puts both
# *.template.conf files flat alongside the script (see README.md step 3),
# so this must point at that same flat directory.
CUSTOM_DOMAIN_TEMPLATE_DIR=/opt/custom-domain-agent

# Optional overrides (defaults shown):
# NGINX_CONF_DIR=/etc/nginx/conf.d
# CUSTOM_DOMAIN_MAX_PENDING_HOURS=48
